	column 'Weather_Conditions (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Data'[Weather_Conditions]),
				"(Blank)",
				'Data'[Weather_Conditions] IN {"Fine + high winds",
					"Fine no high winds"},
				"Fine",
				'Data'[Weather_Conditions] IN {"Other"},
				"Other",
				'Data'[Weather_Conditions] IN {"Raining + high winds",
					"Raining no high winds"},
				"Rain",
				'Data'[Weather_Conditions] IN {"Fog or mist",
					"Snowing + high winds",
					"Snowing no high winds"},
				"Snow/Fog",
				'Data'[Weather_Conditions]
			)
