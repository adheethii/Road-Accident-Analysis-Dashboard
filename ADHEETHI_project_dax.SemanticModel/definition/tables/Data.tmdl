		annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"Data","TableItemName":"Vehicle_Type (groups)","ObjectType":4},"LinkType":"UsedInGroup"}]

	column 'Vehicle_Type (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Data'[Vehicle_Type]),
				"(Blank)",
				'Data'[Vehicle_Type] IN {"Agricultural vehicle"},
				"Agricultural",
				'Data'[Vehicle_Type] IN {"Motorcycle 125cc and under",
					"Motorcycle 50cc and under",
					"Motorcycle over 125cc and up to 500cc",
					"Motorcycle over 500cc",
					"Pedal cycle"},
				"Bike",
				'Data'[Vehicle_Type] IN {"Bus or coach (17 or more pass seats)",
					"Minibus (8 - 16 passenger seats)"},
				"Bus",
				'Data'[Vehicle_Type] IN {"Car",
					"Taxi/Private hire car"},
				"Car",
				'Data'[Vehicle_Type] IN {"Other vehicle",
					"Ridden horse"},
				"Others",
				'Data'[Vehicle_Type] IN {"Goods 7.5 tonnes mgw and over",
					"Goods over 3.5t. and under 7.5t",
					"Van / Goods 3.5 tonnes mgw or under"},
				"Van",
				'Data'[Vehicle_Type]
			)
		lineageTag: bd5e8cf5-91f7-4ad2-a685-abc43a3c0608
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
