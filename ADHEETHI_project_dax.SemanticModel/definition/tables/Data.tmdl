				          "SourceRef": {
				            "Entity": "Data"
				          }
				        },
				        "Property": "Vehicle_Type"
				      }
				    }
				  ]
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"d","Entity":"Data"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"GroupItems":[{"DisplayName":"(Blank)","BlankDefaultPlaceholder":true},{"DisplayName":"Agricultural","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Agricultural vehicle'"}}]]}}},{"DisplayName":"Bike","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Motorcycle 125cc and under'"}}],[{"Literal":{"Value":"'Motorcycle 50cc and under'"}}],[{"Literal":{"Value":"'Motorcycle over 125cc and up to 500cc'"}}],[{"Literal":{"Value":"'Motorcycle over 500cc'"}}],[{"Literal":{"Value":"'Pedal cycle'"}}]]}}},{"DisplayName":"Bus","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Bus or coach (17 or more pass seats)'"}}],[{"Literal":{"Value":"'Minibus (8 - 16 passenger seats)'"}}]]}}},{"DisplayName":"Car","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Car'"}}],[{"Literal":{"Value":"'Taxi/Private hire car'"}}]]}}},{"DisplayName":"Others","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Other vehicle'"}}],[{"Literal":{"Value":"'Ridden horse'"}}]]}}},{"DisplayName":"Van","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"d"}},"Property":"Vehicle_Type"}}],"Values":[[{"Literal":{"Value":"'Goods 7.5 tonnes mgw and over'"}}],[{"Literal":{"Value":"'Goods over 3.5t. and under 7.5t'"}}],[{"Literal":{"Value":"'Van / Goods 3.5 tonnes mgw or under'"}}]]}}}]}

