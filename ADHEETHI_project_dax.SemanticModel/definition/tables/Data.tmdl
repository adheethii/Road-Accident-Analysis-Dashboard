	column 'Road_Surface_Conditions (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Data'[Road_Surface_Conditions]),
				"(Blank)",
				'Data'[Road_Surface_Conditions] IN {"Dry"},
