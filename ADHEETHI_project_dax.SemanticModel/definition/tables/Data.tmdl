	column 'Light_Conditions (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Data'[Light_Conditions]),
				"(Blank)",
				'Data'[Light_Conditions] IN {"Darkness - lighting unknown",
					"Darkness - lights lit",
					"Darkness - lights unlit",
					"Darkness - no lighting"},
				"Dark",
				'Data'[Light_Conditions] IN {"Daylight"},
				"Day",
				'Data'[Light_Conditions]
			)
